{
  "name": "@citesurf/mcp",
  "version": "1.1.3",
  "description": "Citesurf MCP server for AI visibility monitoring",
  "author": "Citesurf (https://www.citesurf.com)",
  "homepage": "https://www.citesurf.com",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/citesurf/mcp"
  },
  "keywords": [
    "mcp",
    "citesurf",
    "ai",
    "visibility",
    "seo",
    "chatgpt",
    "claude",
    "gemini",
    "perplexity",
    "geo",
    "aeo"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "citesurf-mcp": "dist/index.js"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run clean && npm run build && changeset publish"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.5",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1"
  },
  "engines": {
    "node": ">=20"
  }
}
